  // ─── TACTICAL SCENARIO 3: SWAT OPERATION ───
  {
    id: "tactical_scenario_swat",
    title: "⚡ SWAT 작전 의료 지원 — 무장 인질 상황",
    titleEn: "SWAT Operation Medical Support — Armed Hostage Situation",
    description: "서울 도심의 한 은행에서 무장 괴한 3명이 15명의 인질을 붙잡고 대치 중입니다. 당신은 경찰특공대 작전에 배속된 전술 의료 제공자(TMP)입니다. TCCC 3단계와 출혈 통제 처치를 완벽히 수행하여 작전 성공과 인명 피해 최소화를 달성하세요.",
    category: "tccc",
    difficulty: "boss",
    estimatedTime: "30분",
    learningObjectives: [
      "TCCC 3단계 적용",
      "원격 평가 의학(RAM) 기법",
      "REBOA 및 비압축성 몸통 출혈 이해",
      "RSI 약물 선택(에토미데이트 vs 케타민)",
      "양측 지휘(Dual Command) 체계"
    ],
    steps: [
      {
        id: 1,
        situation: "은행 정면에서 특공대가 대치 중입니다. 건물 내부에서 총성이 들렸고, 부상자가 1층 창문에서 보입니다. 직접 접근은 불가능한 핫 존 상태입니다. 당신은 고배율 쌍안경으로 부상자를 관찰하고 있습니다.",
        question: "이 상황에서 원격 평가 의학(RAM, Remote Assessment Medicine)으로 확인해야 할 생존 징후가 아닌 것은?",
        choices: [
          { text: "호흡에 의한 흉부의 미세한 움직임", outcome: "bad", feedback: "호흡에 의한 흉부 움직임은 RAM의 핵심 생존 징후입니다." },
          { text: "팔다리나 머리의 미세한 자발적 움직임", outcome: "bad", feedback: "자발적 움직임은 의식 있는 생존자의 핵심 징후입니다." },
          { text: "동공 크기 및 대광 반사 여부", outcome: "good", feedback: "정답! 동공 반응은 직접 접촉 없이 먼 거리에서 관찰하기 어렵습니다. RAM은 쌍안경, 야간 투시경, 고배율 조준경으로 관찰 가능한 거시적 징후에 집중합니다. 동공 평가는 직접 접근 후 가능합니다." },
          { text: "대량의 혈액 웅덩이 여부", outcome: "bad", feedback: "혈액 웅덩이는 RAM에서 사망 추정 징후로 평가하는 중요한 관찰 항목입니다." }
        ],
        correctChoice: 2,
        medicalInfo: "RAM(Remote Assessment Medicine) 생존 징후: 호흡성 흉부 움직임, 사지/머리 미세 움직임, 의사소통 시도. 사망 추정 징후: 완전한 움직임 없음, 대량 혈액 웅덩이, 창백/청색증 피부, 명백히 생존 불가능한 외상."
      },
      {
        id: 2,
        situation: "협상 중 갑자기 특공대원 1명이 복부에 총상을 입고 쓰러졌습니다. 총격은 계속되고 있습니다. 이는 Care Under Fire(CUF) 상황입니다.",
        question: "CUF 단계에서 즉각적으로 해야 할 처치는?",
